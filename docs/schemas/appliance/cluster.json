{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cluster.json",
  "description": "Configuration for high availability clustering; as well as defining external configuration and runtime database connection properties.",
  "type": "object",
  "properties": {
    "config_database": {
      "$ref": "#/$defs/Database",
      "description": "Configuration for the config database."
    },
    "runtime_database": {
      "$ref": "#/$defs/Database",
      "description": "Configuration for the runtime (HVDB) database."
    },
    "cluster": {
      "$ref": "#/$defs/Cluster",
      "description": "Configuration for Verify Identity Access High Availability cluster nodes."
    }
  },
  "$defs": {
    "Database": {
      "type": "object",
      "description": "External database configuration.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Database type.",
          "enum": [
            "postgresql",
            "db2",
            "oracle"
          ]
        },
        "host": {
          "type": "string",
          "description": "Hostname or address of database."
        },
        "port": {
          "type": "integer",
          "description": "Port database is listening on.",
          "minimum": 1,
          "maximum": 65535
        },
        "ssl": {
          "type": "boolean",
          "description": "Enable SSL encryption of connections."
        },
        "ssl_keystore": {
          "type": "string",
          "description": "SSL database to use to verify connections. Only valid if ssl == true."
        },
        "user": {
          "type": "string",
          "description": "Username to authenticate to database as."
        },
        "password": {
          "type": "string",
          "description": "Password to authenticate as username.",
          "format": "password"
        },
        "db_name": {
          "type": "string",
          "description": "Name of the database instance to use."
        },
        "extra_config": {
          "type": "object",
          "description": "Database type specific configuration.",
          "additionalProperties": true
        }
      },
      "required": [
        "type",
        "host",
        "port",
        "ssl",
        "user",
        "password",
        "db_name"
      ]
    },
    "Cluster": {
      "type": "object",
      "description": "High availability cluster configuration.",
      "properties": {
        "sig_file": {
          "type": "string",
          "description": "Signature file generated by the primary master; used to add nodes to the cluster."
        },
        "primary_master": {
          "type": "string",
          "description": "Verify Identity Access appliance designated as the primary master node."
        },
        "secondary_master": {
          "type": "string",
          "description": "Verify Identity Access appliance designated as the secondary master node."
        },
        "nodes": {
          "type": "array",
          "description": "Verify Identity Access appliance designated as nodes.",
          "items": {
            "type": "string"
          }
        },
        "restricted_nodes": {
          "type": "array",
          "description": "Verify Identity Access appliance designated as the restricted nodes.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "sig_file",
        "primary_master"
      ]
    }
  },
  "examples": [
    {
      "cluster": {
        "config_database": {
          "type": "postgresql",
          "host": "127.0.10.1",
          "port": 1234,
          "user": "database_user",
          "password": "database_password",
          "ssl": true,
          "ssl_keystore": "lmi_trust_store.kdb",
          "db_name": "isva_config"
        },
        "runtime_database": {
          "type": "postgresql",
          "host": "postgresql",
          "port": 5432,
          "user": "postgres",
          "password": "database_password or !secret macro",
          "ssl": false,
          "db_name": "isva_hvdb"
        },
        "cluster": {
          "sig_file": "cluster/signature_file",
          "primary_master": "isva.primary.master",
          "secondary_master": "isva.secondary.master",
          "nodes": [
            "isva.node"
          ],
          "restricted_nodes": [
            "isva.restricted.node"
          ]
        }
      }
    }
  ]
}
